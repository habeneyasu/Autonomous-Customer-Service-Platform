# Application
APP_NAME=Autonomous Customer Service Platform
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/acsp
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# MCP
MCP_SERVER_URL=http://localhost:8001

# Domain
DEFAULT_CURRENCY=ETB
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
IDEMPOTENCY_TTL_SECONDS=86400

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
