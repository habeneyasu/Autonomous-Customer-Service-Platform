# Application
APP_NAME=Autonomous Customer Service Platform
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Database
# If your password contains @, :, /, or ?, URL-encode it (e.g. pass@word -> pass%40word).
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/databasename
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# MCP
MCP_SERVER_URL=http://localhost:8001
MCP_MAX_INVOCATIONS=10

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOOL_ROUNDS=5

# Knowledge / RAG
KNOWLEDGE_INDEX_DIR=.knowledge/chroma

# Domain
DEFAULT_CURRENCY=ETB
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
IDEMPOTENCY_TTL_SECONDS=86400

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
